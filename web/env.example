NEXT_PUBLIC_SUPABASE_URL="https://YOURPROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Server-side only (Next.js route handlers). Do NOT expose to browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Plaid (server-side only)
PLAID_CLIENT_ID="YOUR_PLAID_CLIENT_ID"
PLAID_SECRET="YOUR_PLAID_SECRET"
PLAID_ENV="sandbox"

# Playwright E2E (local only). Create a Supabase user with email/password and use it here.
E2E_EMAIL="test-user@example.com"
E2E_PASSWORD="your-test-password"
